#!/usr/bin/env python3
"""nlpm-badge — convert nlpm-check --json output to a shields.io endpoint JSON.

Reads `nlpm-check --json` output on stdin, writes a shields.io
endpoint-badge JSON to stdout. Use this in CI to publish a
"Validated by NLPM" badge without external services.

Usage:
  nlpm-check --json . | nlpm-badge > nlpm-badge.json
  nlpm-check --json . | nlpm-badge --attestation > nlpm-attestation.json

Then commit nlpm-badge.json to your repo and reference it in README.md:
  ![Validated by NLPM](https://img.shields.io/endpoint?url=https://raw.githubusercontent.com/USER/REPO/main/nlpm-badge.json)

The badge JSON only contains the fields shields.io's endpoint schema
documents. For attestation metadata (checked_at, manifest-consistency
flag, full finding counts), pass --attestation to emit a sidecar JSON.

Reference:
  https://shields.io/badges/endpoint-badge
"""

from __future__ import annotations

import json
import sys
from datetime import datetime, timezone


def build_badge(check_output: dict) -> dict:
    """Map nlpm-check JSON output to a shields-endpoint badge dict.

    Handles both single-plugin and multi-plugin (monorepo) outputs.
    Shields.io's endpoint-badge schema is strict — it rejects unknown
    fields with "invalid properties: <name>" rendered in the badge.
    Only the documented fields below are emitted. For attestation
    metadata, see build_attestation().
    """
    nlpm_version = check_output.get("version", "?")
    mode = check_output.get("mode", "single")
    summary = check_output.get("summary", {})
    high = summary.get("high", 0)
    medium = summary.get("medium", 0)
    low = summary.get("low", 0)

    if mode == "multi":
        total = summary.get("plugins_total", 0)
        clean = summary.get("plugins_clean", 0)
        if high > 0:
            failing = total - clean
            plural = "plugins" if failing != 1 else "plugin"
            message = f"{failing} of {total} {plural} fail · {high} high"
            color = "critical"
        elif medium + low > 0:
            advisory = medium + low
            message = f"{total} plugins · {advisory} advisory"
            color = "important"
        else:
            message = f"{total} plugins clean · v{nlpm_version}"
            color = "success"
    else:
        if high > 0:
            plural = "issues" if high > 1 else "issue"
            message = f"{high} high {plural}"
            color = "critical"
        elif medium + low > 0:
            advisory = medium + low
            message = f"0 high · {advisory} advisory"
            color = "important"
        else:
            message = f"0 issues · v{nlpm_version}"
            color = "success"

    # Shields.io endpoint schema: schemaVersion, label, message, color,
    # labelColor, isError, namedLogo, logoSvg, logoColor, style, cacheSeconds.
    # Unknown fields render as "invalid properties: X" in the badge image.
    return {
        "schemaVersion": 1,
        "label": "nlpm",
        "message": message,
        "color": color,
        "isError": high > 0,
    }


def build_attestation(check_output: dict) -> dict:
    """Sidecar JSON with audit metadata for downstream verification.

    Not consumed by shields.io. Authors who want to expose verifiable
    metadata can publish this alongside nlpm-badge.json as
    nlpm-attestation.json and link it from their docs.

    Format adapts to single-plugin vs multi-plugin input.
    """
    nlpm_version = check_output.get("version", "?")
    mode = check_output.get("mode", "single")
    summary = check_output.get("summary", {})

    if mode == "multi":
        # Aggregate manifest-consistency across all sub-plugins
        manifest_consistent = True
        for sub in check_output.get("plugins", []):
            if any(
                f.get("rule") == "manifest-disk-diff"
                for f in sub.get("findings", [])
            ):
                manifest_consistent = False
                break
        return {
            "checked_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
            "nlpm_version": nlpm_version,
            "mode": "multi",
            "plugins_total": summary.get("plugins_total", 0),
            "plugins_clean": summary.get("plugins_clean", 0),
            "findings": {
                "high": summary.get("high", 0),
                "medium": summary.get("medium", 0),
                "low": summary.get("low", 0),
            },
            "manifest_disk_consistent": manifest_consistent,
        }

    manifest_consistent = not any(
        f.get("rule") == "manifest-disk-diff"
        for f in check_output.get("findings", [])
    )
    return {
        "checked_at": datetime.now(timezone.utc).isoformat(timespec="seconds"),
        "nlpm_version": nlpm_version,
        "mode": "single",
        "findings": {
            "high": summary.get("high", 0),
            "medium": summary.get("medium", 0),
            "low": summary.get("low", 0),
        },
        "manifest_disk_consistent": manifest_consistent,
    }


def main(argv: list[str] | None = None) -> int:
    if argv is None:
        argv = sys.argv[1:]
    if argv and argv[0] in ("-h", "--help"):
        print(__doc__)
        return 0
    if argv and argv[0] == "--version":
        print("nlpm-badge 0.8.6")
        return 0
    emit_attestation = argv and argv[0] == "--attestation"

    raw = sys.stdin.read()
    if not raw.strip():
        print("nlpm-badge: stdin was empty; expected nlpm-check --json output", file=sys.stderr)
        return 2
    try:
        data = json.loads(raw)
    except json.JSONDecodeError as e:
        print(f"nlpm-badge: failed to parse stdin as JSON: {e}", file=sys.stderr)
        return 2

    payload = build_attestation(data) if emit_attestation else build_badge(data)
    json.dump(payload, sys.stdout, indent=2, ensure_ascii=False)
    sys.stdout.write("\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
